# Base URL of the Orderlynk backend API.
# Leave unset in development — Vite proxies /api to http://localhost:8080 (see vite.config.ts).
# Set this for production builds, e.g. https://api.orderlynk.app
VITE_API_URL=

# Stripe publishable key (pk_test_… / pk_live_…) — safe to expose to the browser.
# Used by the Payment Element at checkout. Card payments are disabled without it.
# Put your real value in a git-ignored .env file, not here.
VITE_STRIPE_PUBLISHABLE_KEY=
